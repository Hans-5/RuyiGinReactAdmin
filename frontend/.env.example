# RuyiGinReactAdmin — Frontend Environment Variables
# Copy this file to .env.local for local development overrides.

# Set to "false" to route API calls to a real backend instead of mock data.
# Default: unset (mock mode on)
VITE_USE_MOCK=true

# Base URL for the real Gin backend API.
# Only used when VITE_USE_MOCK=false.
# Example: VITE_API_BASE=http://localhost:8080/api
VITE_API_BASE=/api

# ── Production Deployment Note ──────────────────────────────────────────────
# This app uses BrowserRouter (HTML5 history API).
# Your production server must serve index.html for all unknown routes.
#
# Nginx example:
#   location / {
#     try_files $uri $uri/ /index.html;
#   }
#
# For hash-based routing (no server config needed), swap BrowserRouter
# for HashRouter in src/main.jsx.
