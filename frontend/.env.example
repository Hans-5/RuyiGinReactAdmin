# Data source toggle for the API client (src/api/apiClient.js).
# Leave true (default) to use mock data from config/mockData.js.
# Set to false when the Gin backend is ready — pages don't change.
VITE_USE_MOCK=true

# Base URL for the real backend (only used when VITE_USE_MOCK=false).
VITE_API_BASE=/api
